# Ignore generated output files (HTML, PDF, etc.)
# Modify these patterns based on your specific build setup
*.html
*.pdf
*.epub
*.fo
*.xml

# Optional: Ignore common output directories
/build/
/out/
/generated/
/_resources/generated/

# General system and editor ignore patterns (recommended for all projects)
# Operating System files
.DS_Store
Thumbs.db

# Common Editor/IDE files
.idea
.vscode
*.swp
.project
.classpath

# Build dependencies (if using a build tool like Maven, Gradle, or npm)
/target/
/node_modules/
todo.adoc
